  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ineiti/fledger"
  },
  "keywords": [
    "fledger",
    "wasm",
    "p2p",
    "webrtc"
  ],
  "license": "MIT OR Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
